# ── Data files ────────────────────────────────────────────────────────────
# Raw and processed data files are excluded from the repo.
# See SETUP.md for download instructions.
data/
*.csv
*.json
*.parquet
*.feather

# ── Embeddings ────────────────────────────────────────────────────────────
# Learned embedding weights — regenerated by running notebooks
embeddings/
*.npy

# ── Notebook outputs ──────────────────────────────────────────────────────
# Use nbstripout to clear outputs before committing
# Run: nbstripout --install (sets up pre-commit hook automatically)
# Individual notebooks with outputs can be large (100MB+)
# nbstripout handles this automatically after installation

# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ───────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Kaggle ────────────────────────────────────────────────────────────────
# Kaggle API credentials — never commit these
kaggle.json
.kaggle/

# ── Results ───────────────────────────────────────────────────────────────
# Keep .gitkeep in results folders but exclude actual result files
# Uncomment the lines below if you want to exclude results:
# */results/*.csv
# */results/*.json
